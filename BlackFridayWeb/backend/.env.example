APP_NAME=BlackFridayWeb Backend
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Set a distinct SERVER_INSTANCE_ID when running multi-instance demo.
# Example:
# PORT=5000
# SERVER_INSTANCE_ID=server-A
# PORT=5001
# SERVER_INSTANCE_ID=server-B
SERVER_ID=server-4000
SERVER_INSTANCE_ID=server-4000

# Local demo DB defaults to SQLite.
# For PostgreSQL, switch DB_CLIENT=pg and set DB_URL accordingly.
DB_CLIENT=sqlite3
DB_URL=./data/blackfridayweb.sqlite
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_BUSY_TIMEOUT_MS=5000

# Redis is required for distributed lock verification.
REDIS_URL=redis://localhost:6379/0

# Distributed lock settings
LOCK_TTL_MS=10000
LOCK_RETRY_INTERVAL_MS=50
LOCK_WAIT_TIMEOUT_MS=3000
LOCK_KEY_PREFIX=lock

# JWT auth
JWT_SECRET=change_me_for_demo_and_production
JWT_EXPIRES_IN=1d

# Demo auth defaults used by CLI scripts when they need to call protected admin APIs.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

# No-lock demo race window
NO_LOCK_PURCHASE_DELAY_MS=100
NO_LOCK_PURCHASE_DELAY_MIN_MS=20
NO_LOCK_PURCHASE_DELAY_MAX_MS=200

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Script/reporting overrides used by demo scripts.
REPORT_ENABLED=true
REPORT_DIR=reports
REQUIRE_REDIS_TESTS=false
BASE_URL=http://localhost:4000
BASE_URLS=http://localhost:3000,http://localhost:3001
PRODUCT_ID=
INITIAL_STOCK=1
CONCURRENT_REQUESTS=20
QUANTITY=1
MODE=with-lock
REQUEST_PREFIX=demo-run
REQUEST_TIMEOUT_MS=10000
USER_PREFIX=demo-user
