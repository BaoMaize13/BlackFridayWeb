APP_NAME=BlackFridayWeb Backend
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
SERVER_ID=blackfridayweb-backend-dev
DB_CLIENT=sqlite3
DB_URL=./data/blackfridayweb.sqlite
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_BUSY_TIMEOUT_MS=5000
NO_LOCK_PURCHASE_DELAY_MS=100
REDIS_URL=redis://localhost:6379/0
LOCK_TTL_MS=10000
LOCK_RETRY_INTERVAL_MS=50
LOCK_WAIT_TIMEOUT_MS=3000
LOCK_KEY_PREFIX=lock
LOG_LEVEL=info
LOG_PRETTY=true
