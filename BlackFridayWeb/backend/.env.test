APP_NAME=BlackFridayWeb Backend Test
NODE_ENV=test
HOST=127.0.0.1
PORT=4000
SERVER_ID=backend-test-node
DB_CLIENT=sqlite3
DB_URL=:memory:
DB_POOL_MIN=1
DB_POOL_MAX=1
DB_BUSY_TIMEOUT_MS=5000
NO_LOCK_PURCHASE_DELAY_MS=5
REDIS_URL=redis://127.0.0.1:6379/0
REQUIRE_REDIS_TESTS=false
LOCK_TTL_MS=10000
LOCK_RETRY_INTERVAL_MS=25
LOCK_WAIT_TIMEOUT_MS=5000
LOCK_KEY_PREFIX=test-lock
JWT_SECRET=test-jwt-secret
JWT_EXPIRES_IN=1d
LOG_LEVEL=silent
LOG_PRETTY=false
