{
  "name": "blackfridayweb-backend",
  "version": "1.0.0",
  "description": "Backend foundation for distributed sales dispute simulation",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "node -e \"require('./src/server'); console.log('Backend build check passed')\"",
    "start": "node src/server.js",
    "dev": "node src/scripts/dev-start.js",
    "dev:watch": "nodemon src/scripts/dev-start.js",
    "server:a": "cross-env PORT=5000 SERVER_INSTANCE_ID=server-A npm run dev",
    "server:b": "cross-env PORT=5001 SERVER_INSTANCE_ID=server-B npm run dev",
    "dev:multi": "node scripts/dev-multi.js",
    "dev:server-a": "npm run server:a",
    "dev:server-b": "npm run server:b",
    "test": "npm run test:all",
    "test:unit": "node tests/setup/run-node-tests.js unit",
    "test:integration": "node tests/setup/run-node-tests.js integration",
    "test:edge": "node tests/setup/run-node-tests.js edge",
    "test:concurrency": "node tests/setup/run-node-tests.js concurrency",
    "test:all": "node tests/setup/run-node-tests.js all",
    "test:multi-instance": "node scripts/load-test-multi-server.js",
    "test:multi-instance:with-lock": "cross-env MODE=with-lock node scripts/load-test-multi-server.js",
    "test:multi-instance:no-lock": "cross-env MODE=no-lock node scripts/load-test-multi-server.js",
    "report:compare": "node src/scripts/compare-lock-strategies.js",
    "report:metrics": "node src/scripts/generate-metrics-summary.js",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "redis:logs": "docker compose logs -f redis",
    "db:migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed.js",
    "db:seed": "node src/scripts/seed.js",
    "db:reset": "node src/scripts/reset-data.js",
    "db:list-products": "node src/scripts/list-products.js",
    "test:no-lock": "node scripts/load-test-no-lock.js",
    "evidence:no-lock": "node src/scripts/no-lock-evidence.js",
    "test:with-lock": "node scripts/load-test-with-lock.js",
    "test:compare": "node scripts/load-test-compare.js",
    "test:multi-server": "node scripts/load-test-multi-server.js",
    "test:stress": "node scripts/load-test-stress.js",
    "report:generate": "node scripts/generate-test-report.js",
    "evidence:with-lock": "node src/scripts/with-lock-evidence.js",
    "evidence:multi-instance": "node src/scripts/load-test-multi-instance.js",
    "test:lock": "node src/scripts/test-lock-service.js"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "envalid": "^8.1.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "redis": "^5.12.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.1.2",
    "supertest": "^7.1.4"
  }
}
